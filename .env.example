# SensorTower API Configuration
# Get your API token from: https://app.sensortower.com/api/docs
SENSOR_TOWER_API_TOKEN=your_api_token_here

# SensorTower Cache Configuration (Optional)
SENSORTOWER_CACHE_ENABLED=true
SENSORTOWER_CACHE_TTL=3600
SENSORTOWER_CACHE_DIR=.cache/sensortower

# Linkup API (Web Search with Citations & Deep Research)
# Get your API key from: https://linkup.so
# LINKUP_API_KEY=your_api_key_here

# Kilo Gateway (Research LLM Router — cheap models for research synthesis)
# Get your API key from: https://kilo.ai
# KILO_API_KEY=your_kilo_gateway_api_key_here

# Other MCP Server Tokens (Add as needed)
# GOOGLE_SEARCH_CONSOLE_CREDENTIALS=path/to/credentials.json
# META_ADS_ACCESS_TOKEN=your_token_here
# META_AD_ACCOUNT_ID=act_123456789
# META_PAGE_ID=your_page_id
# HUBSPOT_API_KEY=your_api_key_here

# AI Image/Video Generation
# REPLICATE_API_TOKEN=your_token_here
# KIE_AI_API_KEY=your_key_here
# OPENART_API_KEY=your_key_here

# Google Gemini API (Image Generation + Research)
# Get keys at: https://aistudio.google.com/apikey
# Multiple keys = round-robin for batch image gen (3 keys = 3x throughput)
# GEMINI_API_KEY=your_key_here
# GEMINI_API_KEY_2=your_second_key_here
# GEMINI_API_KEY_3=your_third_key_here

# Postiz (Self-hosted Social Publishing)
# POSTIZ_API_KEY=your_postiz_api_key_here
# POSTIZ_API_URL=http://localhost:4007

# ScrapeCreators (TikTok Competitor Intelligence)
# Get your API key from: https://app.scrapecreators.com
# SCRAPECREATORS_API_KEY=your_api_key_here

# Netlify (Site Deploys & Hosting)
# Get your token from: https://app.netlify.com/account/applications#personal-access-tokens
# NETLIFY_PERSONAL_ACCESS_TOKEN=your_token_here

# Email Marketing
# MAILCHIMP_API_KEY=your_key_here
# SENDGRID_API_KEY=your_key_here
